{
  "buildCommand": "",
  "outputDirectory": ".",
  "framework": null,
  "routes": [
    { "src": "/imagens/(.*)", "dest": "/Imagens/$1" },
    { "src": "^/$", "dest": "/newlandingpage/index.html" },
    { "src": "^/kanban$", "dest": "/newlandingpage/signum-kanban.html" },
    { "src": "^/talentos$", "dest": "/newlandingpage/talentos.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
